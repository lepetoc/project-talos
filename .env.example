# Required — the application will not start without this set.
# Use a long, random value in production; never commit a real secret here.
TALOS_JWT_SECRET=changeme

# Optional — defaults to 30 if unset.
TALOS_EXIT_DELAY_SECS=30

# Optional — defaults to 30 if unset.
TALOS_ENTRY_DELAY_SECS=30

# Optional — defaults to sqlite://talos.db if unset.
TALOS_DATABASE_URL=sqlite://talos.db

# Optional — defaults to "info" if unset. Controls log level/filtering; see
# https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=info

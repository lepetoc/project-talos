# Required — the application will not start without this set.
# Recommended to use a long random string like a UUID
# Generate one with the command openssl rand -base64 48
TALOS_JWT_SECRET=changeme

# Optional — defaults to 30 if unset.
TALOS_EXIT_DELAY_SECS=30

# Optional — defaults to 30 if unset.
TALOS_ENTRY_DELAY_SECS=30

# Optional — defaults to sqlite://talos.db if unset.
TALOS_DATABASE_URL=sqlite://talos.db

# Optional — defaults to 127.0.0.1:3000 if unset.
TALOS_BIND_ADDR=127.0.0.1:3000

# Optional — defaults to "info" if unset. Controls log level/filtering; see
# https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=info

# Optional — comma-separated list of origins allowed to make cross-origin
# requests to the API (e.g. https://talos.example.com,http://10.1.11.50:3000).
# Leaving this unset blocks all cross-origin requests, the safe default.
TALOS_ALLOWED_ORIGINS=
